{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
  ],
  packageRules: [
    {
      matchCategories: ["*"],
      minimumReleaseAge: "7 days",
    },
    {
      // disable version updates for JavaScript packages
      matchCategories: ["js"],
      enabled: false,
    },
    {
      // avoid floating tags for GitHub actions
      "matchManagers": ["github-actions"],
      "rangeStrategy": "pin"
    },
  ],
  // enable security updates, also for JavaScript packages
  osvVulnerabilityAlerts: true,
  vulnerabilityAlerts: {
    enabled: true,
  },
}
