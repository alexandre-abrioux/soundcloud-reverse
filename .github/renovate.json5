{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  packageRules: [
    {
      matchCategories: ["*"],
      minimumReleaseAge: "7 days",
    },
    {
      // disable version updates for JavaScript packages
      matchCategories: ["js"],
      enabled: false,
    },
  ],
  // enable security updates, also for JavaScript packages
  osvVulnerabilityAlerts: true,
  vulnerabilityAlerts: {
    enabled: true,
  },
}
